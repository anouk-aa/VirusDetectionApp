@page "/submissions"
@rendermode InteractiveServer
@using VirusDetectionApp.Models
@using VirusDetectionApp.Services
@implements IAsyncDisposable
@inject IJSRuntime JS

<style>
    body.submissions-orbs-active .app-bg .orb {
        display: block;
        animation: none;
        opacity: 0.58;
        filter: blur(74px);
    }

    body.submissions-orbs-active .app-bg .orb-1 {
        width: var(--sub-orb-1-size, 1000px);
        height: var(--sub-orb-1-size, 1000px);
        background: radial-gradient(circle, rgba(194,249,112,0.72) 0%, transparent 68%);
        transform: translate3d(var(--sub-orb-1-x, -300px), var(--sub-orb-1-y, -300px), 0);
        top: 0;
        left: 0;
    }

    body.submissions-orbs-active .app-bg .orb-2 {
        width: var(--sub-orb-2-size, 900px);
        height: var(--sub-orb-2-size, 900px);
        background: radial-gradient(circle, rgba(255,39,165,0.68) 0%, transparent 68%);
        transform: translate3d(var(--sub-orb-2-x, 0px), var(--sub-orb-2-y, 0px), 0);
        top: 0;
        left: 0;
    }

    body.submissions-orbs-active .app-bg .orb-3 {
        width: var(--sub-orb-3-size, 920px);
        height: var(--sub-orb-3-size, 920px);
        background: radial-gradient(circle, rgba(80,40,180,0.55) 0%, transparent 68%);
        transform: translate3d(var(--sub-orb-3-x, 0px), var(--sub-orb-3-y, 0px), 0);
        top: 0;
        left: 0;
    }

    .loader {
        height: 8px;
        aspect-ratio: 6;
        --c: #0000 64%, #FF007F 66% 98%, #0000 101%;
        background:
            radial-gradient(35% 146% at 50% 159%, var(--c)) 0 0,
            radial-gradient(35% 146% at 50% -59%, var(--c)) 25% 100%;
        background-size: calc(100% / 3) 50%;
        background-repeat: repeat-x;
        clip-path: inset(0 100% 0 0);
        animation: l2 1s infinite linear;
    }
    @@keyframes l2 {
        90%, to { clip-path: inset(0); }
    }

    .btn-export {
        display: inline-block;
        background: rgba(0, 204, 255, 0.15);
        color: #fff !important;
        border: 1px solid rgba(0, 204, 255, 0.45);
        border-radius: 10px;
        padding: 0.55rem 1.5rem;
        font-size: 1rem;
        font-family: inherit;
        text-decoration: none !important;
        cursor: pointer;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition: background 0.2s, box-shadow 0.2s;
        box-shadow: 0 2px 12px rgba(0,204,255,0.15);
    }
    .btn-export:hover {
        background: rgba(0, 204, 255, 0.28);
        box-shadow: 0 4px 20px rgba(0,204,255,0.30);
    }

    .page-title-gradient {
        display: inline-block;
        background: linear-gradient(90deg, #31d7ff 0%, #8d7bff 45%, #ff67b7 100%);
        background-size: 100% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
    }
</style>

<h2 class="page-title-gradient">Submissions</h2>

<p>
    <a href="/export/submissions" target="_blank" class="btn-export">Download Excel Export</a>
</p>

<p>Last updated: @lastUpdated</p>

@inject SubmissionService SubmissionService

@if (submissions == null)
{
    <p>Loading...</p>
}
else if (submissions.Count == 0)
{
    <p>No submissions found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Source</th>
                <th>Reason</th>
                <th>Submitted</th>
                <th>Status</th>
                <th>Scan Summary</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var submission in submissions)
            {
                <tr>
                    <td>@submission.FileName</td>
                    <td>@submission.Source</td>
                    <td>@submission.ReasonForSuspicion</td>
                    <td>@submission.SubmittedAt</td>
                    <td>@submission.Status</td>
                    <td>
                        @if (submission.Status == "Completed" || submission.Status == "Failed")
                        {
                            @submission.ScanSummary
                        }
                        else
                        {
                            <div style="display:flex; align-items:center; gap:0.75rem;">
                                <span>@submission.ScanSummary</span>
                                <div class="loader" style="height:8px; flex-shrink:0;"></div>
                            </div>
                        }
                    </td>
                    <td>
                        <button @onclick="() => DeleteSubmissionAsync(submission.Id)"
                                disabled="@(deletingId == submission.Id)">
                            @(deletingId == submission.Id ? "Deleting..." : "Delete")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Submission>? submissions;
    private string lastUpdated = "";
    private PeriodicTimer? timer;
    private CancellationTokenSource? cts;
    private int? deletingId;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubmissionsAsync();

        cts = new CancellationTokenSource();
        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _ = RunPollingAsync(cts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("initSubmissionsOrbs");
            }
            catch (JSException)
            {
            }
            catch (InvalidOperationException)
            {
            }
        }
    }

    private async Task RunPollingAsync(CancellationToken token)
    {
        try
        {
            while (timer != null && await timer.WaitForNextTickAsync(token))
            {
                await LoadSubmissionsAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task LoadSubmissionsAsync()
    {
        submissions = await SubmissionService.GetAllSubmissionsAsync();
        lastUpdated = DateTime.Now.ToString("HH:mm:ss");
    }

    private async Task DeleteSubmissionAsync(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this submission?");
        if (!confirmed)
        {
            return;
        }

        deletingId = id;

        try
        {
            await SubmissionService.DeleteSubmissionAsync(id);
            await LoadSubmissionsAsync();
        }
        finally
        {
            deletingId = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        cts?.Cancel();
        timer?.Dispose();
        cts?.Dispose();

        try
        {
            await JS.InvokeVoidAsync("stopSubmissionsOrbs");
        }
        catch (JSException)
        {
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
